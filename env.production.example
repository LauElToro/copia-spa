# ===================================
# Variables de Entorno - Producción
# ===================================
# Copia este archivo a .env.production y configura las URLs correctas de tus microservicios

# URLs de Microservicios de Producción
# Reemplaza con tus URLs reales de producción
NEXT_PUBLIC_MS_AUTH_URL=https://auth.libertyclub.io
NEXT_PUBLIC_MS_ACCOUNT_URL=https://account.libertyclub.io
NEXT_PUBLIC_MS_PLANS_URL=https://plans.libertyclub.io
NEXT_PUBLIC_MS_STORAGE_URL=https://storage.libertyclub.io
NEXT_PUBLIC_MS_TRANSACTIONS_URL=https://transactions.libertyclub.io
NEXT_PUBLIC_MS_PRODUCTS_URL=https://products.libertyclub.io
NEXT_PUBLIC_MS_NOTIFICATIONS_URL=https://notifications.libertyclub.io
NEXT_PUBLIC_MS_ROLES_PERMISSIONS_URL=https://roles-permissions.libertyclub.io
NEXT_PUBLIC_MS_QUESTIONS_ANSWERS_URL=https://questions-answers.libertyclub.io
NEXT_PUBLIC_MS_STORES_URL=https://stores.libertyclub.io
NEXT_PUBLIC_MS_WALLETS_URL=https://wallets.libertyclub.io
NEXT_PUBLIC_MS_PAYMENTS_URL=https://payments.libertyclub.io
NEXT_PUBLIC_MS_SHIPPINGS_URL=https://shippings.libertyclub.io

# Libia AI API
NEXT_PUBLIC_LIBIA_API_URL=https://libia.libertyclub.io

# API de persistencia de configuración Libia (comercios_ia).
# Si se define, GET/POST de config hacen proxy a este backend.
# Ej: https://api.libertyclub.io/api/v1/libia/comercio/config
# LIBIA_CONFIG_API_URL=

# Email de destino para formulario de contacto (Soporte)
NEXT_PUBLIC_CONTACT_EMAIL=contacto@libertyclub.io

# Credenciales del SPA para obtener JWT y poder llamar ms-notifications
# (usuario técnico con permiso notifications:send)
NEXT_PUBLIC_SERVICE_SPA_AUTH_EMAIL=service-spa@libertyclub.io
NEXT_PUBLIC_SERVICE_SPA_AUTH_PASSWORD=changeme_seguro

# Configuración de NextAuth
NEXTAUTH_URL=https://libertyclub.io
NEXTAUTH_SECRET=tu_clave_secreta_muy_larga_y_segura_para_produccion

